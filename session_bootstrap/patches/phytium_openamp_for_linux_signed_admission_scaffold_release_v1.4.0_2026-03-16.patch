+static int sc_ctrl_lookup_public_key_slot(uint8_t key_slot,
+                                          const ScPublicKeySlot **out_slot)
+{
+    size_t entry_index;
+
+    for (entry_index = 0; entry_index < (sizeof(sc_public_key_slots) /
+                                         sizeof(sc_public_key_slots[0]));
+         ++entry_index)
+    {
+        const ScPublicKeySlot *entry = &sc_public_key_slots[entry_index];
+
+        if ((entry->slot_id == key_slot) && (entry->key_id != NULL))
+        {
+            if (out_slot != NULL)
+            {
+                *out_slot = entry;
+            }
+            return 1;
+        }
+    }
+
+    if (out_slot != NULL)
+    {
+        *out_slot = NULL;
+    }
+    return 0;
+}
