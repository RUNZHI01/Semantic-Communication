+static const uint8_t sc_trusted_sha256[32] = {
+    0x6f, 0x23, 0x6b, 0x07, 0xf9, 0xb0, 0xbf, 0x98,
+    0x1b, 0x67, 0x62, 0xdd, 0xb7, 0x24, 0x49, 0xe2,
