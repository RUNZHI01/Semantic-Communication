+    ScCtrlHdr header;
+    ScJobAck payload;
+} ScJobAckFrame;
+static const uint8_t sc_trusted_sha256[32] =
+{
+    0x6f, 0x23, 0x6b, 0x07, 0xf9, 0xb0, 0xbf, 0x98,
+    0x1b, 0x67, 0x62, 0xdd, 0xb7, 0x24, 0x49, 0xe2,
+    0x33, 0x32, 0xd2, 0xd9, 0x2c, 0x76, 0xb3, 0x8a,
+    0xcd, 0xca, 0xdc, 0x1d, 0x9b, 0x53, 0x6d, 0xc1
+};
+static uint32_t sc_guard_state = SC_GUARD_STATE_READY;
+static uint32_t sc_active_job_id = 0U;
+static uint32_t sc_last_fault_code = SC_FAULT_NONE;
+static uint32_t sc_sticky_fault = 0U;
+static uint32_t sc_total_fault_count = 0U;
+static uint32_t sc_last_job_ack_decision = SC_DECISION_DENY;
 /************************** Function Prototypes ******************************/
 static uint32_t sc_ctrl_crc32(const void *data, size_t len)
 {
@@ -207,22 +250,104 @@ static int sc_ctrl_send_status_resp(struct rpmsg_endpoint *ept, uint32_t src,
     response.header.seq = request_header->seq;
