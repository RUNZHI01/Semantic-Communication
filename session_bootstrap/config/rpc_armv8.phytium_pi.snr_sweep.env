# ARMv8 真机 RPC 调优配置（飞腾派，2026-03-01）
# 说明：
# - 连接信息来自 /home/tianxing/phytium_downloads_structure.md
# - TVM Python 固定为 /home/user/anaconda3/envs/tvm310/bin/python（conda Python 3.10；已验证兼容 TVM 0.24）
# - QUICK/FULL payload 已替换为远端真实 TVM 推理命令（tvm_001.py / tvm_002.py）

PROJECT_NAME=tvm_metaschedule_rpc_armv8_phytium_pi
MODEL_NAME=jscc
# 2026-03-08 target refresh:
# - legacy JSCC Phytium config already used generic + neon only
# - local LLVM 18 does not accept mcpu=phytium / ft2000plus for aarch64-linux-gnu
# - keep the runnable/evidence-backed subset here as well
TARGET='llvm -mtriple=aarch64-linux-gnu -mcpu=generic -mattr=+neon'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=10.194.7.123
RPC_TRACKER_PORT=9190
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9090
RPC_SERVER_PORT_END=9099
TVM_PYTHON=/home/user/anaconda3/envs/tvm310/bin/python

REMOTE_HOST=10.194.7.123
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_DOWNLOADS_DIR=/home/user/Downloads
REMOTE_TVM_PYTHON=/home/user/anaconda3/envs/tvm310/bin/python
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_PRIMARY_SO=/home/user/Downloads/5.1TVM优化结果/tvm_tune_logs/optimized_model.so
REMOTE_TVM_PRIMARY_DB_RECORD=/home/user/Downloads/5.1TVM优化结果/tuning_logs/database_tuning_record.json
REMOTE_TVM_PRIMARY_DB_WORKLOAD=/home/user/Downloads/5.1TVM优化结果/tuning_logs/database_workload.json
REMOTE_TVM_ALT_DIR=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs
REMOTE_TVM_ALT_SO=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs/optimized_model.so
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_TVM_JSCC_3000_DIR=/home/user/Downloads/jscc-test/jscc/tvm_3000_optimize
REMOTE_TVM_JSCC_DYNAMIC20_DIR=/home/user/Downloads/jscc-test/jscc/tvm_optimize_dymatic_20
REMOTE_JSCC_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_INPUT_DIR=/home/user/Downloads/jscc-test/简化版latent
REMOTE_OUTPUT_BASE=/home/user/Downloads/jscc-test/jscc/infer_outputs
REMOTE_SNR_BASELINE=10
REMOTE_SNR_CURRENT=14
REMOTE_BATCH_BASELINE=1
REMOTE_BATCH_CURRENT=1
REMOTE_FULL_BASELINE_ARCHIVES=/home/user/Downloads/5.1TVM优化结果,/home/user/Downloads/jscc-test/jscc,/home/user/Downloads/jscc-test/jscc/tvm_3000_optimize
REMOTE_FULL_CURRENT_ARCHIVES=/home/user/Downloads/jscc-test/jscc,/home/user/Downloads/jscc-test/jscc/tvm_3000_optimize,/home/user/Downloads/jscc-test/jscc/tvm_optimize_dymatic_20

TUNING_DB_DIR=./session_bootstrap/tmp/rpc_armv8_phytium_pi_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=1
QUICK_TIMEOUT_SEC=2700
QUICK_BUDGET_SEC_PER_ARCHIVE=900
QUICK_MIN_ROUNDS=20
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "set -euo pipefail && cd \"$REMOTE_JSCC_DIR\" && mkdir -p \"$REMOTE_OUTPUT_BASE/quick_baseline\" && \"$REMOTE_TVM_PYTHON\" "tvm_001.py" --input_dir \"$REMOTE_INPUT_DIR\" --output_dir \"$REMOTE_OUTPUT_BASE/quick_baseline\" --snr \"$REMOTE_SNR_BASELINE\""'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "set -euo pipefail && cd \"$REMOTE_JSCC_DIR\" && mkdir -p \"$REMOTE_OUTPUT_BASE/quick_current\" && \"$REMOTE_TVM_PYTHON\" "tvm_001.py" --input_dir \"$REMOTE_INPUT_DIR\" --output_dir \"$REMOTE_OUTPUT_BASE/quick_current\" --snr \"$REMOTE_SNR_CURRENT\""'

FULL_TIMEOUT_SEC=5400
FULL_BUDGET_SEC_PER_ARCHIVE=300
FULL_MIN_ROUNDS=15
FULL_HOTSPOT_TASKS=tvm_main_archive,jscc_main_archive,jscc_tvm_3000_archive,jscc_dynamic20_archive
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "set -euo pipefail && cd \"$REMOTE_JSCC_DIR\" && mkdir -p \"$REMOTE_OUTPUT_BASE/full\" && \"$REMOTE_TVM_PYTHON\" "tvm_002.py" --input_dir \"$REMOTE_INPUT_DIR\" --output_dir \"$REMOTE_OUTPUT_BASE/full\" --snr \"$REMOTE_SNR_BASELINE\" --batch_size \"$REMOTE_BATCH_BASELINE\""'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "set -euo pipefail && cd \"$REMOTE_JSCC_DIR\" && mkdir -p \"$REMOTE_OUTPUT_BASE/full\" && \"$REMOTE_TVM_PYTHON\" "tvm_002.py" --input_dir \"$REMOTE_INPUT_DIR\" --output_dir \"$REMOTE_OUTPUT_BASE/full\" --snr \"$REMOTE_SNR_CURRENT\" --batch_size \"$REMOTE_BATCH_CURRENT\""'
FULL_NOTES='real TVM inference via tvm_002.py; single-variable experiment keeps batch fixed at 1 and changes only SNR'

EXECUTION_ID=quick_rpc_armv8_phytium_realcmd_round1
FULL_EXECUTION_ID=full_rpc_armv8_phytium_realcmd_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_armv8_phytium_realcmd_round1.md

DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='change only tvm_002.py snr: REMOTE_SNR_BASELINE=10 -> REMOTE_SNR_CURRENT=14 (batch fixed at 1)'
DAILY_NEXT_CHANGE='run SNR sweep with batch fixed at 1 (e.g., 8/10/12/14) and compare stability'
