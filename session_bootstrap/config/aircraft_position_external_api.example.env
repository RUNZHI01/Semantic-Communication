# Example configuration for wiring a purchased external positioning API
# into the OpenAMP demo aircraft-position bridge.
#
# Usage:
# 1. Copy the needed keys into your active board-access env or runtime env.
# 2. Point AIRCRAFT_POSITION_UPSTREAM_URL at a provider endpoint that returns
#    a JSON object containing at least latitude/longitude.
# 3. Override field paths if the provider uses different JSON keys.
#
# If the provider requires custom headers:
# AIRCRAFT_POSITION_UPSTREAM_HEADERS_JSON='{"Authorization":"Bearer <token>"}'
#
# If the provider requires query-string auth, include it directly in
# AIRCRAFT_POSITION_UPSTREAM_URL.

# Required:
AIRCRAFT_POSITION_EXECUTION_MODE=local
AIRCRAFT_POSITION_UPSTREAM_URL=https://example-provider.invalid/api/v1/position?token=<replace-me>

# The demo backend base URL that receives normalized position samples.
AIRCRAFT_POSITION_BACKEND_BASE_URL=http://127.0.0.1:8079

# Optional provider headers.
AIRCRAFT_POSITION_UPSTREAM_HEADERS_JSON=

# Optional metadata shown by the demo UI.
AIRCRAFT_POSITION_SOURCE_LABEL=External live positioning API
AIRCRAFT_POSITION_SOURCE_NOTE=Live aircraft position is currently sourced from an external purchased positioning feed.
AIRCRAFT_POSITION_PRODUCER_ID=external-position-api-bridge
AIRCRAFT_POSITION_TRANSPORT=external_http_get
AIRCRAFT_POSITION_AIRCRAFT_ID=
AIRCRAFT_POSITION_MISSION_CALL_SIGN=

# Optional polling knobs.
AIRCRAFT_POSITION_INTERVAL_SEC=1.0
AIRCRAFT_POSITION_TIMEOUT_SEC=3.0

# Optional scales. Keep 1.0 when provider already returns these units:
# - ground speed: kph
# - altitude: meters
# - vertical speed: m/s
AIRCRAFT_POSITION_GROUND_SPEED_SCALE=1.0
AIRCRAFT_POSITION_ALTITUDE_SCALE=1.0
AIRCRAFT_POSITION_VERTICAL_SPEED_SCALE=1.0

# Optional dotted-path overrides.
# The bridge already auto-detects common names:
# latitude: position.latitude / latitude / lat
# longitude: position.longitude / longitude / lon / lng
# altitude: kinematics.altitude_m / altitude_m / altitude
# speed: kinematics.ground_speed_kph / ground_speed_kph / ground_speed / speed_kph / speed
# heading: kinematics.heading_deg / heading_deg / heading
# vertical speed: kinematics.vertical_speed_mps / vertical_speed_mps / vertical_speed
#
# Set these only when your provider uses different JSON keys.
AIRCRAFT_POSITION_LATITUDE_PATH=
AIRCRAFT_POSITION_LONGITUDE_PATH=
AIRCRAFT_POSITION_ALTITUDE_M_PATH=
AIRCRAFT_POSITION_GROUND_SPEED_KPH_PATH=
AIRCRAFT_POSITION_HEADING_DEG_PATH=
AIRCRAFT_POSITION_VERTICAL_SPEED_MPS_PATH=
AIRCRAFT_POSITION_FIX_TYPE_PATH=
AIRCRAFT_POSITION_CONFIDENCE_M_PATH=
AIRCRAFT_POSITION_SATELLITES_PATH=
AIRCRAFT_POSITION_CAPTURED_AT_PATH=
AIRCRAFT_POSITION_SEQUENCE_PATH=
