# Phytium Pi TVM 0.24dev safe runtime env (isolated from broken tvm310)
#
# Purpose:
#   - use the working tvm310_safe import path on the Pi
#   - keep original tvm310 untouched
#   - serve as the next-step baseline for real target experiments
#
# Important:
#   - TVM 0.24dev here expects JSON/dict-form target objects, not old CLI strings
#   - current safe runtime import requires disabling eager torch dlpack bootstrap

MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"generic","mattr":["+neon"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4
TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_DTYPE=float32

REMOTE_MODE=ssh
REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22

REMOTE_TVM_SAFE_ENV=/home/user/anaconda3/envs/tvm310_safe
REMOTE_TVM_SAFE_BUILD=/home/user/tvm_samegen_safe_20260309/build
REMOTE_TVM_SAFE_PYTHON=/home/user/tvm_samegen_20260307/python
REMOTE_TVM_PYTHON='env TVM_FFI_DISABLE_TORCH_C_DLPACK=1 LD_LIBRARY_PATH=/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages/tvm_ffi/lib:/home/user/tvm_samegen_safe_20260309/build TVM_LIBRARY_PATH=/home/user/tvm_samegen_safe_20260309/build PYTHONPATH=/home/user/tvm_samegen_20260307/python:/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages /home/user/anaconda3/envs/tvm310_safe/bin/python'
REMOTE_TVM310_PYTHON='env TVM_FFI_DISABLE_TORCH_C_DLPACK=1 LD_LIBRARY_PATH=/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages/tvm_ffi/lib:/home/user/tvm_samegen_safe_20260309/build TVM_LIBRARY_PATH=/home/user/tvm_samegen_safe_20260309/build PYTHONPATH=/home/user/tvm_samegen_20260307/python:/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages /home/user/anaconda3/envs/tvm310_safe/bin/python'

REMOTE_TORCH_PYTHONPATH=
REMOTE_JSCC_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_INPUT_DIR=/home/user/Downloads/jscc-test/简化版latent
REMOTE_OUTPUT_BASE=/home/user/Downloads/jscc-test/jscc/infer_outputs
REMOTE_BASELINE_ARTIFACT=/home/user/Downloads/5.1TVM优化结果/tvm_tune_logs/optimized_model.so
REMOTE_CURRENT_ARTIFACT=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs/optimized_model.so
INFERENCE_CURRENT_EXPECTED_SHA256=d8e801eeb25a87d340311015fe475f00d0f324dacd88bd5936654d3eedd03cc6
REMOTE_SNR_BASELINE=10
REMOTE_SNR_CURRENT=10
REMOTE_BATCH_BASELINE=1
REMOTE_BATCH_CURRENT=1
INFERENCE_TIMEOUT_SEC=3600
INFERENCE_REPEAT=1
INFERENCE_WARMUP_RUNS=0
INFERENCE_EXECUTION_ID=inference_tvm310_safe_20260310_round1
INFERENCE_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_legacy_tvm_compat.sh --variant baseline'
INFERENCE_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_legacy_tvm_compat.sh --variant current'
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports
