# Recommended current rebuild-only target for Phytium Pi under safe TVM 0.24.dev0
# Chosen after 2026-03-10 comparison under safe runtime.
# Reason: strong median + better stability than the more aggressive variants.

PROJECT_NAME=tvm_metaschedule_rpc_tune_phytium
MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"cortex-a72","mattr":["+neon"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_MODE=remote
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=100.121.87.73
RPC_TRACKER_PORT=9190
RPC_RUNNER_TRACKER_HOST=127.0.0.1
RPC_SERVER_CUSTOM_ADDR=100.121.87.73
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9092
RPC_SERVER_PORT_END=9099

LOCAL_TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python
TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python

REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22
REMOTE_TVM_PYTHON='env LD_LIBRARY_PATH=/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages/tvm_ffi/lib:/home/user/tvm_samegen_safe_20260309/build TVM_LIBRARY_PATH=/home/user/tvm_samegen_safe_20260309/build PYTHONPATH=/home/user/tvm_samegen_20260307/python:/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages /home/user/anaconda3/envs/tvm310_safe/bin/python'

ONNX_MODEL_PATH=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc/model.onnx
REMOTE_ONNX_PATH=/home/user/Downloads/temp_simp.onnx

TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_NAME=input
TUNE_INPUT_DTYPE=float32
TUNE_TOTAL_TRIALS=0
TUNE_MAX_TRIALS_PER_TASK=
TUNE_NUM_TRIALS_PER_ITER=64
TUNE_OUTPUT_DIR=./session_bootstrap/tmp/rebuild_current_safe_recommended_cortex_a72_neon_20260310
TUNE_EXISTING_DB=./session_bootstrap/tmp/rpc_tune_output_20260306_195752/tuning_logs
TUNE_TIMEOUT_SEC=7200
TUNE_SESSION_TIMEOUT=120
TUNE_RUNNER=local
TUNE_MODE_LABEL=rebuild_current_safe_recommended_cortex_a72_neon
TUNING_DB_DIR=./session_bootstrap/tmp/rpc_tune_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports
REMOTE_MODE=ssh
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_BASELINE_ARCHIVES=/home/user/Downloads/5.1TVM优化结果,/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_CURRENT_ARCHIVES=/home/user/Downloads/jscc-test/jscc
REMOTE_PAYLOAD_LOAD_DB=0
