# Phytium Pi 真机 RPC MetaSchedule 调优配置（round1 warm-start）
# 目标：停止“0 trial + local rebuild”假调优，切换到真正的 device-guided tuning。
#
# 使用方式：
#   bash ./session_bootstrap/scripts/manage_rpc_services.sh --env ./session_bootstrap/config/rpc_tune_real.2026-03-09.phytium_pi.env start-all
#   bash ./session_bootstrap/scripts/check_rpc_readiness.sh --env ./session_bootstrap/config/rpc_tune_real.2026-03-09.phytium_pi.env
#   python ./session_bootstrap/scripts/extract_hotspot_tasks.py --env ./session_bootstrap/config/rpc_tune_real.2026-03-09.phytium_pi.env --top-k 8
#   bash ./session_bootstrap/scripts/run_rpc_tune.sh --env ./session_bootstrap/config/rpc_tune_real.2026-03-09.phytium_pi.env --skip-full

PROJECT_NAME=tvm_metaschedule_rpc_tune_phytium
MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"generic","mattr":["+neon"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_MODE=remote
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=100.121.87.73
RPC_TRACKER_PORT=9190
RPC_RUNNER_TRACKER_HOST=127.0.0.1
RPC_SERVER_CUSTOM_ADDR=100.121.87.73
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9092
RPC_SERVER_PORT_END=9099

LOCAL_TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python
TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python

REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22
REMOTE_TVM_PYTHON='env PYTHONPATH=/home/user/tvm_compat_20260306/python TVM_LIBRARY_PATH=/home/user/tvm_compat_20260306/build /home/user/venv/bin/python'

ONNX_MODEL_PATH=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc/model.onnx
REMOTE_ONNX_PATH=/home/user/Downloads/temp_simp.onnx

TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_NAME=input
TUNE_INPUT_DTYPE=float32
TUNE_TOTAL_TRIALS=500
TUNE_MAX_TRIALS_PER_TASK=64
TUNE_NUM_TRIALS_PER_ITER=32
TUNE_OUTPUT_DIR=./session_bootstrap/tmp/rpc_tune_output_20260309_real_round1
TUNE_EXISTING_DB=./session_bootstrap/tmp/rpc_tune_output_20260306_195752/tuning_logs
TUNE_TIMEOUT_SEC=7200
TUNE_SESSION_TIMEOUT=180
TUNE_RUNNER=rpc
TUNE_REQUIRE_REAL=1
TUNE_MODE_LABEL=phytium_real_rpc_round1_warmstart

TUNING_DB_DIR=./session_bootstrap/tmp/rpc_tune_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=3
QUICK_TIMEOUT_SEC=2700
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant baseline'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant current'

FULL_TIMEOUT_SEC=5400
FULL_HOTSPOT_TASKS=mirror_pad1,mirror_pad2,mirror_pad
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant baseline'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant current'
FULL_NOTES='real RPC tuning round1 warm-start on Phytium Pi; use hotspot extractor output before expanding trials'

REMOTE_MODE=ssh
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_BASELINE_ARCHIVES=/home/user/Downloads/5.1TVM优化结果,/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_CURRENT_ARCHIVES=/home/user/Downloads/jscc-test/jscc
QUICK_BUDGET_SEC_PER_ARCHIVE=300
QUICK_MIN_ROUNDS=10
FULL_BUDGET_SEC_PER_ARCHIVE=180
FULL_MIN_ROUNDS=10
REMOTE_PAYLOAD_LOAD_DB=0

EXECUTION_ID=quick_rpc_tune_20260309_real_round1
FULL_EXECUTION_ID=full_rpc_tune_20260309_real_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_tune_20260309_real_round1.md

DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='switch from local rebuild-only flow to real rpc runner tuning with 500 warm-started trials'
DAILY_NEXT_CHANGE='compare current-vs-current_old gain, then decide whether to raise budget to 1000-2000 trials or refocus on runtime path'
