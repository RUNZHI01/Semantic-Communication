# ARMv8 RPC Tune 配置（笔记本 builder/tracker + 飞腾派 runner）
#
# 使用方式：
#   1) cp config/rpc_armv8.phytium_rpc_tune.env config/rpc_tune_local.env
#   2) 填写下方 ONNX_MODEL_PATH、REMOTE_* 等字段
#   3) 首次运行前：bash scripts/manage_rpc_services.sh --env config/rpc_tune_local.env prepare
#   4) 一键闭环：bash scripts/run_rpc_tune.sh --env config/rpc_tune_local.env
#
# 架构说明：
#   笔记本（骁龙 ARM）：tracker + builder + 搜索/编译（算力强）
#   飞腾派（ARMv8）：rpc_server，只做测量（算力弱，但数据真实）

PROJECT_NAME=tvm_metaschedule_rpc_tune_phytium
MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"generic","mattr":["+neon","+crypto","+crc"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

# === RPC 拓扑 ===
DEVICE_KEY=armv8
RPC_TRACKER_BIND_HOST=0.0.0.0
# 重要：这里填笔记本的局域网 IP（飞腾派需要能访问到）
RPC_TRACKER_HOST=100.121.87.73
RPC_TRACKER_PORT=9190
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9090
RPC_SERVER_PORT_END=9099

# === 笔记本本机 TVM Python ===
LOCAL_TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python
TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python

# === 飞腾派 SSH 连接 ===
REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22
REMOTE_TVM_PYTHON=/home/user/anaconda3/envs/tvm310/bin/python

# === ONNX 模型（tune 输入）===
# 本机路径（首次用 manage_rpc_services.sh prepare 从飞腾派拉取）
ONNX_MODEL_PATH=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc/model.onnx
# 飞腾派上的 ONNX 路径（prepare 命令的源）
REMOTE_ONNX_PATH=/home/user/Downloads/temp_simp.onnx

# === MetaSchedule Tune 参数 ===
TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_NAME=input
TUNE_INPUT_DTYPE=float32
TUNE_TOTAL_TRIALS=500
TUNE_MAX_TRIALS_PER_TASK=
TUNE_NUM_TRIALS_PER_ITER=64
TUNE_OUTPUT_DIR=./session_bootstrap/tmp/rpc_tune_output
TUNE_EXISTING_DB=
TUNE_TIMEOUT_SEC=7200
TUNE_SESSION_TIMEOUT=120
TUNE_RUNNER=rpc

# === 产物路径 ===
TUNING_DB_DIR=./session_bootstrap/tmp/rpc_tune_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

# === Quick 对比（tune 后自动运行）===
# baseline: 飞腾派上原有的 .so（通过 SSH 执行）
# current: tune 产出的新 .so（通过 SSH 部署到飞腾派后执行）
QUICK_REPEAT=3
QUICK_TIMEOUT_SEC=2700
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant baseline'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant current'

# === Full 对比 ===
FULL_TIMEOUT_SEC=5400
FULL_HOTSPOT_TASKS=tvm_main_archive,jscc_main_archive,jscc_tvm_3000_archive,jscc_dynamic20_archive
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant baseline'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant current'
FULL_NOTES='RPC tune: search+compile on laptop, measure on phytium'

# === Remote payload 参数（run_remote_tvm_payload.sh 使用）===
REMOTE_MODE=ssh
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_BASELINE_ARCHIVES=/home/user/Downloads/5.1TVM优化结果,/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_CURRENT_ARCHIVES=/home/user/Downloads/jscc-test/jscc
QUICK_BUDGET_SEC_PER_ARCHIVE=300
QUICK_MIN_ROUNDS=10
FULL_BUDGET_SEC_PER_ARCHIVE=180
FULL_MIN_ROUNDS=10

# === 执行 ID（每轮自动覆盖）===
EXECUTION_ID=quick_rpc_tune_round1
FULL_EXECUTION_ID=full_rpc_tune_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_tune_round1.md

# === 日报字段 ===
DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='RPC tune: laptop builder/tracker + phytium runner, total_trials=500'
DAILY_NEXT_CHANGE='analyze tune results, adjust total_trials or hot-spot task list'
