# quick 最小闭环验证专用配置
# 用于验证 run_quick.sh 的链路与落盘，不依赖 TVM 构建。

PROJECT_NAME=tvm_metaschedule_session_smoke
MODEL_NAME=smoke_demo
TARGET=smoke_target
SHAPE_BUCKETS=64
THREADS=1
DEVICE_KEY=local
RPC_TRACKER_HOST=
RPC_TRACKER_PORT=9190
TVM_PYTHON=
TUNING_DB_DIR=./session_bootstrap/tmp/smoke_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=2
QUICK_TIMEOUT_SEC=10
QUICK_BASELINE_CMD='sleep 2'
QUICK_CURRENT_CMD='sleep 0.5'

FULL_TIMEOUT_SEC=10
FULL_BASELINE_CMD='sleep 1.2'
FULL_CURRENT_CMD='sleep 0.4'
FULL_NOTES='smoke run for full skeleton'

EXECUTION_ID=quick_smoke
FULL_EXECUTION_ID=full_smoke
