# ARMv8 真机 RPC 调优配置（lenovo 开发机专用，2026-03-01）
# 说明：本文件用于“本仓库内编排与落盘”的首轮闭环。
# - 已落本机实值：路径、端口、目标三元组、脚本入口
# - 待你补充真机实值：MODEL_NAME、DEVICE_KEY、RPC_TRACKER_HOST（若 tracker 不在本机）
# - 当前 quick/full payload 已切换为真实 TVM prep 入口（run_remote_tvm_payload.sh）
# - 约束：作为 snapdragon prep，本文件的 MODEL/TARGET/SHAPE/THREADS 必须与 phytium final 对齐
# - 你必须补齐 REMOTE_* 的骁龙连接与归档路径，否则 readiness 会拦截

PROJECT_NAME=tvm_metaschedule_rpc_armv8_lenovo
MODEL_NAME=jscc
TARGET='llvm -mtriple=aarch64-linux-gnu -mcpu=generic -mattr=+neon,+crypto,+crc'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=127.0.0.1
RPC_TRACKER_PORT=9190
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9090
RPC_SERVER_PORT_END=9099
TVM_PYTHON=python3

# Snapdragon prep 远端执行参数（当前先复用可达飞腾派链路，后续可替换为骁龙机实值）
REMOTE_MODE=ssh
REMOTE_HOST=10.194.7.123
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_TVM_PYTHON=/home/user/venv/bin/python
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_FULL_BASELINE_ARCHIVES=/home/user/Downloads/5.1TVM优化结果,/home/user/Downloads/jscc-test/jscc,/home/user/Downloads/jscc-test/jscc/tvm_3000_optimize
REMOTE_FULL_CURRENT_ARCHIVES=/home/user/Downloads/jscc-test/jscc,/home/user/Downloads/jscc-test/jscc/tvm_3000_optimize,/home/user/Downloads/jscc-test/jscc/tvm_optimize_dymatic_20

TUNING_DB_DIR=./session_bootstrap/tmp/rpc_armv8_lenovo_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=1
QUICK_TIMEOUT_SEC=2700
QUICK_BUDGET_SEC_PER_ARCHIVE=300
QUICK_MIN_ROUNDS=10
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant baseline'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant current'

FULL_TIMEOUT_SEC=5400
FULL_BUDGET_SEC_PER_ARCHIVE=180
FULL_MIN_ROUNDS=10
FULL_HOTSPOT_TASKS=tvm_primary_archive,jscc_base_archive,jscc_3000_archive,jscc_dynamic20_archive
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant baseline'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant current'
FULL_NOTES='real TVM prep payload via run_remote_tvm_payload.sh on snapdragon host'

EXECUTION_ID=quick_rpc_armv8_lenovo_round1
FULL_EXECUTION_ID=full_rpc_armv8_lenovo_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_armv8_lenovo_round1.md

DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='switch snapdragon prep payload from mock commands to real TVM runtime/db probe while keeping phytium target fixed'
DAILY_NEXT_CHANGE='run closed-loop prep with current real remote values, then validate transfer on phytium final; replace REMOTE_* with snapdragon real values when available'
