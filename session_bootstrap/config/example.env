# TVM MetaSchedule 会话环境样例（run_quick.sh 所需最小字段）
# 复制为本地配置文件后再填写真实值

PROJECT_NAME=tvm_metaschedule_session
MODEL_NAME=example_model
TARGET=llvm
SHAPE_BUCKETS=64,128,256,512
THREADS=4
DEVICE_KEY=armv8
RPC_TRACKER_HOST=
RPC_TRACKER_PORT=9190
TVM_PYTHON=
TUNING_DB_DIR=./db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

# quick 模式配置
QUICK_REPEAT=5
QUICK_TIMEOUT_SEC=30

# 以下命令请替换为真实 baseline/current 执行命令
QUICK_BASELINE_CMD='echo "run baseline" && sleep 0.02'
QUICK_CURRENT_CMD='echo "run current" && sleep 0.01'

# full 模式骨架配置（未设置时可回退到 QUICK_* 命令）
FULL_TIMEOUT_SEC=0
FULL_BASELINE_CMD='echo "run full baseline" && sleep 0.05'
FULL_CURRENT_CMD='echo "run full current" && sleep 0.04'
FULL_NOTES=

# 可选：手动指定执行ID，不填则自动按时间生成
EXECUTION_ID=
FULL_EXECUTION_ID=

# summarize_to_daily.sh 可选字段
DAILY_OWNER=
DAILY_SINGLE_CHANGE=
DAILY_NEXT_CHANGE=
