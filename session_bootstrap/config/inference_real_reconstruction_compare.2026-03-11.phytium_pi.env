# Real reconstruction compare on the Phytium Pi.
#
# Semantics:
#   - baseline stays on the trusted legacy realcmd compat wrapper
#   - current uses the current-safe runtime but follows real reconstruction
#     semantics: read inputs, decode, write outputs, emit timing logs

MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"cortex-a72","mattr":["+neon"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4
TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_DTYPE=float32
TUNE_INPUT_NAME=input

LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

REMOTE_MODE=ssh
REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22

# Current-safe runtime for the current artifact; baseline wrapper will still
# prefer REMOTE_TVM310_PYTHON below.
REMOTE_TVM_PYTHON='env TVM_FFI_DISABLE_TORCH_C_DLPACK=1 LD_LIBRARY_PATH=/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages/tvm_ffi/lib:/home/user/tvm_samegen_safe_20260309/build TVM_LIBRARY_PATH=/home/user/tvm_samegen_safe_20260309/build PYTHONPATH=/home/user/tvm_samegen_20260307/python:/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages /home/user/anaconda3/envs/tvm310_safe/bin/python'
REMOTE_TVM310_PYTHON=/home/user/venv/bin/tvm_compat_python.sh
# Sidecar torch path for loading .pt latent inputs while the main runtime stays on tvm310_safe.
REMOTE_TORCH_PYTHONPATH=/home/user/anaconda3/envs/myenv/lib/python3.10/site-packages
REMOTE_REAL_EXTRA_PYTHONPATH=/home/user/anaconda3/envs/myenv/lib/python3.10/site-packages

REMOTE_JSCC_DIR=/home/user/Downloads/jscc-test/jscc
REMOTE_INPUT_DIR=/home/user/Downloads/jscc-test/简化版latent
REMOTE_OUTPUT_BASE=/home/user/Downloads/jscc-test/jscc/infer_outputs

REMOTE_BASELINE_ARTIFACT=/home/user/Downloads/5.1TVM优化结果/tvm_tune_logs/optimized_model.so
REMOTE_CURRENT_ARTIFACT=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs/optimized_model.so
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc

REMOTE_SNR_BASELINE=10
REMOTE_SNR_CURRENT=10
REMOTE_BATCH_BASELINE=1
REMOTE_BATCH_CURRENT=1

INFERENCE_TIMEOUT_SEC=7200
INFERENCE_REPEAT=1
INFERENCE_WARMUP_RUNS=0
INFERENCE_EXECUTION_ID=inference_real_reconstruction_compare_20260311

INFERENCE_OUTPUT_PREFIX=inference_real_reconstruction_compare_20260311
INFERENCE_LEGACY_OUTPUT_PREFIX=inference_real_reconstruction_compare_20260311

INFERENCE_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_legacy_tvm_compat.sh --variant baseline'
INFERENCE_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_current_real_reconstruction.sh --variant current'

INFERENCE_CURRENT_EXPECTED_SHA256=1946b08e6cf20a1259fa43f9e849a06f50ae1230c08d4df7081fba1edae4c644
