# 飞腾派 SSH 登录配置样例
# 使用方式：
# 1) cp ./session_bootstrap/config/phytium_pi_login.example.env ./session_bootstrap/config/phytium_pi_login.env
# 2) 按需填写密码（可留空）
# 3) 运行：bash ./session_bootstrap/scripts/connect_phytium_pi.sh --env ./session_bootstrap/config/phytium_pi_login.env

# HOST: 飞腾派主机地址（默认 100.121.87.73）
PHYTIUM_PI_HOST=100.121.87.73

# USER: 登录用户名（默认 user）
PHYTIUM_PI_USER=user

# PORT: SSH 端口（默认 22）
PHYTIUM_PI_PORT=22

# PASSWORD: 可选。留空时走普通 ssh（交互输入密码）。
# 若填写且系统安装了 sshpass，则 connect_phytium_pi.sh 可非交互登录。
PHYTIUM_PI_PASSWORD=
