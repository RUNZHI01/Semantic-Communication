# MNN benchmark matrix example for the Phytium Pi.
#
# This file is intentionally focused on the new MNN harness:
#   bash ./session_bootstrap/scripts/run_mnn_benchmark.sh --env ./session_bootstrap/config/mnn_benchmark.phytium_pi.example.env

LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

REMOTE_MODE=ssh
REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22

# Confirmed working board-side Python/MNN environment.
REMOTE_MNN_PYTHON=/home/user/anaconda3/envs/MNN/bin/python

# Board-side latent inputs and benchmark output root.
REMOTE_INPUT_DIR=/home/user/Downloads/jscc-test/encoder_outputs
REMOTE_OUTPUT_BASE=/home/user/Downloads/jscc-test/mnn_benchmark_outputs
REMOTE_SNR_CURRENT=10

# Known model assets on the board.
MNN_FP32_MODEL=/home/user/Downloads/MNNversion/origin/model1.mnn
# Fill these in after conversion when they exist.
MNN_FP16_MODEL=
MNN_INT8_MODEL=

# Matrix knobs.
MNN_INTERPRETER_COUNTS=1,2
MNN_THREAD_COUNTS=1,2,4
MNN_PRECISIONS=normal,low
MNN_SHAPE_MODES=dynamic
MNN_BUCKET_SHAPES=
MNN_WARMUP_INPUTS=1
MNN_AUTO_BACKEND=0
MNN_TUNE_NUM=20
MNN_MAX_INPUTS=300
MNN_SEED=0
MNN_OUTPUT_PREFIX=mnn_benchmark

# Quality is optional and path-dependent. Enable after you confirm the
# reference reconstruction directory on the board.
MNN_QUALITY_MODE=off
MNN_QUALITY_REF_DIR=
MNN_QUALITY_MAX_IMAGES=300
MNN_QUALITY_LPIPS=auto
