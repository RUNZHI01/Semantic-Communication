# ARMv8 本机执行配置（snapdragon local，2026-03-01）
# 说明：
# - 目标参数保持飞腾派一致（用于保证迁移意义）
# - 执行机改为本机（REMOTE_MODE=local），不依赖 SSH/飞腾派网络
# - 运行前需确认 archive 下存在：
#   tvm_tune_logs/optimized_model.so
#   tuning_logs/database_workload.json
#   tuning_logs/database_tuning_record.json

PROJECT_NAME=tvm_metaschedule_rpc_armv8_snapdragon_local
MODEL_NAME=jscc
TARGET='llvm -mtriple=aarch64-linux-gnu -mcpu=generic -mattr=+neon,+crypto,+crc'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=127.0.0.1
RPC_TRACKER_PORT=9190
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9090
RPC_SERVER_PORT_END=9099
TVM_PYTHON=python3

REMOTE_MODE=local
REMOTE_TVM_PYTHON=/home/tianxing/.venvs/tvm-ms/bin/python
REMOTE_TVM_PRIMARY_DIR=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc
REMOTE_TVM_JSCC_BASE_DIR=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc
REMOTE_FULL_BASELINE_ARCHIVES=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc
REMOTE_FULL_CURRENT_ARCHIVES=/home/tianxing/TVM_LAST/finalWork/服务端/jscc-test/jscc

TUNING_DB_DIR=./session_bootstrap/tmp/rpc_armv8_snapdragon_local_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=1
QUICK_TIMEOUT_SEC=180
QUICK_BUDGET_SEC_PER_ARCHIVE=8
QUICK_MIN_ROUNDS=3
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant baseline'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile quick --variant current'

FULL_TIMEOUT_SEC=5400
FULL_BUDGET_SEC_PER_ARCHIVE=180
FULL_MIN_ROUNDS=10
FULL_HOTSPOT_TASKS=tvm_primary_archive,jscc_base_archive,jscc_3000_archive,jscc_dynamic20_archive
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant baseline'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/run_remote_tvm_payload.sh --profile full --variant current'
FULL_NOTES='local TVM prep payload via run_remote_tvm_payload.sh on snapdragon machine'

EXECUTION_ID=quick_rpc_armv8_snapdragon_local_round1
FULL_EXECUTION_ID=full_rpc_armv8_snapdragon_local_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_armv8_snapdragon_local_round1.md

DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='switch prep execution host to local snapdragon while keeping phytium target fixed'
DAILY_NEXT_CHANGE='ensure local archives contain tvm_tune_logs + tuning_logs artifacts, then run closed-loop prep'
