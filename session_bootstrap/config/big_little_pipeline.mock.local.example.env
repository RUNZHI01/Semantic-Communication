# Local/mock validation template for the big.LITTLE pipeline scaffolding.
#
# This is for repo-side validation only. It does not require TVM and does not
# touch the board. Create mock latent files and a placeholder artifact locally,
# then run:
#   bash ./session_bootstrap/scripts/run_big_little_pipeline.sh --env <copied-env> --variant current

MODEL_NAME=jscc_mock
TARGET=mock_target
SHAPE_BUCKETS=1x32x32x32
THREADS=2
TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_DTYPE=float32
TUNE_INPUT_NAME=input

LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

REMOTE_MODE=local
REMOTE_TVM_PYTHON=/usr/bin/python3
REMOTE_INPUT_DIR=./session_bootstrap/tmp/big_little_mock_inputs
REMOTE_OUTPUT_BASE=./session_bootstrap/tmp/big_little_mock_outputs
REMOTE_CURRENT_ARTIFACT=./session_bootstrap/tmp/big_little_mock_artifact/optimized_model.so
REMOTE_SNR_CURRENT=12
REMOTE_BATCH_CURRENT=1

BIG_LITTLE_BIG_CORES=0
BIG_LITTLE_LITTLE_CORES=1
BIG_LITTLE_BACKEND=threads
BIG_LITTLE_ALLOW_MISSING_AFFINITY=1
BIG_LITTLE_INPUT_QUEUE_SIZE=2
BIG_LITTLE_OUTPUT_QUEUE_SIZE=2
BIG_LITTLE_DRY_RUN=1
BIG_LITTLE_MOCK_INFER_MS=10
BIG_LITTLE_MAX_INPUTS=8
BIG_LITTLE_OUTPUT_PREFIX=big_little_pipeline_mock
BIG_LITTLE_REPORT_PREFIX=big_little_pipeline_mock
