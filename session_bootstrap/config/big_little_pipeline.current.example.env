# big.LITTLE current-path execution template.
#
# Tomorrow's intended flow:
#   1. Copy this file to a private env file.
#   2. Run the read-only topology helper:
#        python3 ./session_bootstrap/scripts/big_little_topology_probe.py ssh --env <copied-env>
#   3. Fill BIG_LITTLE_BIG_CORES / BIG_LITTLE_LITTLE_CORES from the suggested mapping.
#   4. Run:
#        bash ./session_bootstrap/scripts/run_big_little_pipeline.sh --env <copied-env> --variant current
#        bash ./session_bootstrap/scripts/run_big_little_compare.sh --env <copied-env>

MODEL_NAME=jscc
TARGET='{"kind":"llvm","mtriple":"aarch64-linux-gnu","mcpu":"cortex-a72","mattr":["+neon"],"num-cores":4}'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4
TUNE_INPUT_SHAPE=1,32,32,32
TUNE_INPUT_DTYPE=float32
TUNE_INPUT_NAME=input

LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

REMOTE_MODE=ssh
REMOTE_HOST=100.121.87.73
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_SSH_PORT=22

REMOTE_TVM_PYTHON='env TVM_FFI_DISABLE_TORCH_C_DLPACK=1 LD_LIBRARY_PATH=/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages/tvm_ffi/lib:/home/user/tvm_samegen_safe_20260309/build TVM_LIBRARY_PATH=/home/user/tvm_samegen_safe_20260309/build PYTHONPATH=/home/user/tvm_samegen_20260307/python:/home/user/anaconda3/envs/tvm310_safe/lib/python3.10/site-packages /home/user/anaconda3/envs/tvm310_safe/bin/python'
REMOTE_INPUT_DIR=/home/user/Downloads/jscc-test/简化版latent
REMOTE_OUTPUT_BASE=/home/user/Downloads/jscc-test/big_little_runs

REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_JSCC_BASE_DIR=/home/user/Downloads/jscc-test/jscc
INFERENCE_BASELINE_ARCHIVE=/home/user/Downloads/5.1TVM优化结果
INFERENCE_CURRENT_ARCHIVE=/home/user/Downloads/jscc-test/jscc

REMOTE_SNR_BASELINE=12
REMOTE_BATCH_BASELINE=1
REMOTE_SNR_CURRENT=12
REMOTE_BATCH_CURRENT=1
INFERENCE_CURRENT_EXPECTED_SHA256=1946b08e6cf20a1259fa43f9e849a06f50ae1230c08d4df7081fba1edae4c644

# Fill these after the read-only topology probe.
BIG_LITTLE_BIG_CORES=0,1
BIG_LITTLE_LITTLE_CORES=2,3
BIG_LITTLE_BACKEND=processes

# Keep this at 0 for the first real board run so affinity failure is visible.
BIG_LITTLE_ALLOW_MISSING_AFFINITY=0
BIG_LITTLE_INPUT_QUEUE_SIZE=4
BIG_LITTLE_OUTPUT_QUEUE_SIZE=4
BIG_LITTLE_DRY_RUN=0
BIG_LITTLE_MOCK_INFER_MS=15
BIG_LITTLE_MAX_INPUTS=300
BIG_LITTLE_OUTPUT_PREFIX=big_little_pipeline
BIG_LITTLE_REPORT_PREFIX=big_little_pipeline

# Existing wrappers can reuse this for resource profiling tomorrow.
BIG_LITTLE_SERIAL_CMD='bash ./session_bootstrap/scripts/run_remote_current_real_reconstruction.sh --variant current'
BIG_LITTLE_PIPELINE_CMD='bash ./session_bootstrap/scripts/run_big_little_pipeline.sh --variant current'
INFERENCE_CURRENT_CMD='bash ./session_bootstrap/scripts/run_big_little_pipeline.sh --variant current'
