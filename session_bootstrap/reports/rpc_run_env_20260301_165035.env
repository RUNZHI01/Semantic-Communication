# ARMv8 真机 RPC 调优配置（飞腾派，2026-03-01）
# 说明：
# - 连接信息来自 /home/tianxing/phytium_downloads_structure.md
# - TVM Python 固定为 /home/user/venv/bin/python（非 conda，直接使用远端 venv）
# - QUICK/FULL payload 为可执行远端检查命令（用于首轮接入与路径校验）

PROJECT_NAME=tvm_metaschedule_rpc_armv8_phytium_pi
MODEL_NAME=jscc
TARGET='llvm -mtriple=aarch64-linux-gnu -mattr=+neon'
SHAPE_BUCKETS=1x3x224x224,1x3x256x256
THREADS=4

DEVICE_KEY=armv8
RPC_TRACKER_BIND_HOST=0.0.0.0
RPC_TRACKER_HOST=10.194.7.123
RPC_TRACKER_PORT=9190
RPC_SERVER_HOST=0.0.0.0
RPC_SERVER_PORT=9090
RPC_SERVER_PORT_END=9099
TVM_PYTHON=/home/user/venv/bin/python

REMOTE_HOST=10.194.7.123
REMOTE_USER=user
REMOTE_PASS=user
REMOTE_DOWNLOADS_DIR=/home/user/Downloads
REMOTE_TVM_PYTHON=/home/user/venv/bin/python
REMOTE_TVM_PRIMARY_DIR=/home/user/Downloads/5.1TVM优化结果
REMOTE_TVM_PRIMARY_SO=/home/user/Downloads/5.1TVM优化结果/tvm_tune_logs/optimized_model.so
REMOTE_TVM_PRIMARY_DB_RECORD=/home/user/Downloads/5.1TVM优化结果/tuning_logs/database_tuning_record.json
REMOTE_TVM_PRIMARY_DB_WORKLOAD=/home/user/Downloads/5.1TVM优化结果/tuning_logs/database_workload.json
REMOTE_TVM_ALT_DIR=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs
REMOTE_TVM_ALT_SO=/home/user/Downloads/jscc-test/jscc/tvm_tune_logs/optimized_model.so

TUNING_DB_DIR=./session_bootstrap/tmp/rpc_armv8_phytium_pi_db
LOG_DIR=./session_bootstrap/logs
REPORT_DIR=./session_bootstrap/reports

QUICK_REPEAT=1
QUICK_TIMEOUT_SEC=180
QUICK_BASELINE_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "test -f \"$REMOTE_TVM_PRIMARY_SO\" && test -f \"$REMOTE_TVM_PRIMARY_DB_RECORD\" && test -f \"$REMOTE_TVM_PRIMARY_DB_WORKLOAD\" && \"$REMOTE_TVM_PYTHON\" -c \"import tvm; print(tvm.__version__)\""'
QUICK_CURRENT_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "test -d \"$REMOTE_TVM_ALT_DIR\" && test -f \"$REMOTE_TVM_ALT_SO\" && ls -lh \"$REMOTE_TVM_ALT_SO\""'

FULL_TIMEOUT_SEC=600
FULL_HOTSPOT_TASKS=tvm_main_archive,jscc_experiment_archive,db_integrity
FULL_BASELINE_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "sha256sum \"$REMOTE_TVM_PRIMARY_SO\" \"$REMOTE_TVM_PRIMARY_DB_RECORD\" \"$REMOTE_TVM_PRIMARY_DB_WORKLOAD\""'
FULL_CURRENT_CMD='bash ./session_bootstrap/scripts/ssh_with_password.sh --host "$REMOTE_HOST" --user "$REMOTE_USER" --pass "$REMOTE_PASS" -- "find \"$REMOTE_DOWNLOADS_DIR\" -type f -name \"optimized_model.so\" | sort && echo \"---\" && find \"$REMOTE_DOWNLOADS_DIR\" -type f -name \"database_tuning_record.json\" | sort && find \"$REMOTE_DOWNLOADS_DIR\" -type f -name \"database_workload.json\" | sort"'
FULL_NOTES='phytium remote artifact/db verification before replacing payload with true TVM tuning runner'

EXECUTION_ID=quick_rpc_armv8_phytium_round1
FULL_EXECUTION_ID=full_rpc_armv8_phytium_round1
DAILY_REPORT_FILE=./session_bootstrap/reports/daily_rpc_armv8_phytium_round1.md

DAILY_OWNER=tianxing
DAILY_SINGLE_CHANGE='wire rpc first-round env to phytium board ip/key/python/path variables'
DAILY_NEXT_CHANGE='replace remote verification payload with real TVM RPC tuning/eval command'

EXECUTION_ID=quick_rpc_armv8_phytium_round1
FULL_EXECUTION_ID=full_rpc_armv8_phytium_round1
